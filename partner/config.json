                    "action": {
                        "type": "string",
                        "description": "对话结束后角色的行为。"
                    },
                    "location": {
                        "type": "string",
                        "description": "对话结束后角色的位置。"
                    },
                    "is_completion": {
                        "type": "boolean",
                        "description": "对话结束后是否完成与用户约定的事件。"
                    },
                    "is_new_event": {
                        "type": "boolean",
                        "description": "对话结束后是否产生新的与用户约定的事件。"
                    },
                    "new_event": {
                        "type": "string",
                        "description": "若 is_new_event 为 true，这里写新的约定事件；否则写空字符串。",
                        "default": ""
                    },
                    "message": {
                        "type": "string",
                        "description": "你的回复内容（对用户说的话）。"
                    }
                },
                "required": [
                    "time_period",
                    "is_user_nearby",
                    "action",
                    "location",
                    "is_completion",
                    "is_new_event",
                    "new_event",
                    "message"
                ],
                "additionalProperties": false
            }
        }
    },
    "response_rule_object": {
